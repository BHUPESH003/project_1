# Server Configuration
PORT=3001
NODE_ENV=development
APP_NAME=ExpressAPI

# MongoDB Configuration
# Local: mongodb://localhost:27017/express-api
# Atlas: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/express-api
MONGODB_URI=mongodb://localhost:27017/express-api

# API Keys and Secrets (add as needed)
JWT_SECRET=your_jwt_secret_key_here

# Logging
LOG_LEVEL=debug

# CORS Configuration
CORS_ORIGIN=*
