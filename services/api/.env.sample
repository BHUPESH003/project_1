# ========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ========================================
# DO NOT commit this file with real credentials
# Copy this to .env.production and fill with actual values
# ========================================

# ========================================
# APPLICATION CONFIGURATION
# ========================================

NODE_ENV=production

# Server configuration
PORT=3000
API_PREFIX=api
API_VERSION=1

# ========================================
# CORS CONFIGURATION
# ========================================

CORS_ENABLED=true
CORS_ORIGINS=https://your-frontend-domain.com,https://app.your-domain.com

# ========================================
# DATABASE CONFIGURATION
# ========================================

# Connection pooled via PgBouncer or similar
# Use connection pooler URL (e.g., Railway, Render, Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:PORT/DATABASE?schema=public&pgbouncer=true"

# Direct connection for migrations (bypass pooler)
# Use direct database URL (required for migrations)
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST:PORT/DATABASE?schema=public"

# ========================================
# AUTHENTICATION & SECURITY
# ========================================

# JWT Configuration
# CRITICAL: Use strong secret, minimum 32 characters
JWT_SECRET=GENERATE_SECURE_RANDOM_STRING_MINIMUM_32_CHARS
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# OTP Provider (Twilio)
OTP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_production_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# OTP Provider (Infobip) - Alternative to Twilio
# Set OTP_PROVIDER=infobip to use Infobip instead of Twilio
INFOBIP_BASE_URL=https://your-infobip-api-url.com
INFOBIP_API_KEY=your_infobip_api_key
INFOBIP_SENDER=your_sender_id_or_long_code

# ========================================
# PAYMENTS (PAYTM INTEGRATION)
# ========================================

# Paytm Payment Gateway Configuration
PAYTM_MERCHANT_ID=your_production_paytm_merchant_id
PAYTM_MERCHANT_KEY=your_production_paytm_merchant_key
PAYTM_ENV=production
PAYTM_WEBSITE=WEBPROD
PAYTM_CHANNEL_ID=WAP
PAYTM_INDUSTRY_TYPE=Retail
PAYTM_CALLBACK_URL=https://your-api-domain.com/api/internal/payments/webhook

# ========================================
# PAYMENTS (RAZORPAY INTEGRATION)
# ========================================

# Razorpay Payment Gateway Configuration
RAZORPAY_KEY_ID=your_production_razorpay_key_id
RAZORPAY_KEY_SECRET=your_production_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_production_razorpay_webhook_secret
RAZORPAY_ENV=production

# ========================================
# DELIVERY (UBER DIRECT INTEGRATION)
# ========================================

# Uber Direct Delivery Provider Configuration
UBER_CLIENT_ID=your_production_uber_client_id
UBER_CLIENT_SECRET=your_production_uber_client_secret
UBER_CUSTOMER_ID=your_production_uber_customer_id
UBER_ENV=production
UBER_WEBHOOK_SECRET=your_production_uber_webhook_secret

# ========================================
# QUEUES (REDIS)
# ========================================

# Redis Configuration for Queue Management
REDIS_URL=redis://username:password@host:port
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=your_production_redis_password

# ========================================
# FILE STORAGE (AWS S3)
# ========================================

# AWS S3 Configuration for File Uploads
S3_BUCKET_NAME=your-production-bucket
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ========================================
# NOTIFICATIONS
# ========================================

# Firebase Cloud Messaging (FCM) for Push Notifications
FIREBASE_PROJECT_ID=your-production-firebase-project-id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nyour_production_firebase_private_key\n-----END PRIVATE KEY-----
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_API_KEY=your_production_firebase_api_key

# SMS Provider (Twilio) for SMS Notifications
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_production_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ========================================
# RATE LIMITING
# ========================================

# Note: Currently hardcoded in app.module.ts
# TODO: Make configurable via environment variables
# THROTTLE_TTL=60000
# THROTTLE_LIMIT=100

# ========================================
# MONITORING & LOGGING (Optional)
# ========================================

# Sentry Error Tracking
# SENTRY_DSN=https://xxxx@sentry.io/xxxxx

# New Relic Application Monitoring
# NEW_RELIC_LICENSE_KEY=your_license_key
# NEW_RELIC_APP_NAME=mvp-api-production
# Sentry Error Tracking
# SENTRY_DSN=https://xxxx@sentry.io/xxxxx

# New Relic Application Monitoring
# NEW_RELIC_LICENSE_KEY=your_license_key
# NEW_RELIC_APP_NAME=mvp-api-production

# ========================================
# WHATSAPP BUSINESS API (Phase 4)
# ========================================
# Meta WhatsApp Cloud API credentials
# Get from: https://developers.facebook.com/apps > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_permanent_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_whatsapp_webhook_verify_token

# ========================================
# GOOGLE MAPS / PLACES API (Phase 5)
# ========================================
# Used for: reverse geocoding (LocationService) + seller discovery (DiscoveryService)
# Requires: Maps JavaScript API, Places API, Geocoding API enabled on the key
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ========================================
# RATE LIMITING (Phase 6)
# ========================================
# Override defaults set in app.module.ts
# Default: 100 requests per 60 seconds for authenticated users
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ========================================
# ORDER CONFIGURATION (Phase 6)
# ========================================
# Minutes a seller has to accept an order after payment before it expires
ORDER_TIMEOUT_MINUTES=30

# ========================================
# S3 PUBLIC BASE URL (optional)
# ========================================
# If using CloudFront or a custom CDN in front of S3, set this instead of
# constructing the URL from S3_BUCKET_NAME + AWS_REGION
# S3_PUBLIC_BASE_URL=https://cdn.your-domain.com

# ========================================
# SENTRY ERROR TRACKING (Phase 6 — optional)
# ========================================
# SENTRY_DSN=https://xxxx@sentry.io/xxxxx
