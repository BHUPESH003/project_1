# ========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ========================================
# DO NOT commit this file with real credentials
# Copy this to .env.production and fill with actual values
# ========================================

# ========================================
# DATABASE CONFIGURATION (PRODUCTION)
# ========================================

# Connection pooled via PgBouncer or similar
# Use connection pooler URL (e.g., Railway, Render, Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:PORT/DATABASE?schema=public&pgbouncer=true"

# Direct connection for migrations (bypass pooler)
# Use direct database URL (required for migrations)
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST:PORT/DATABASE?schema=public"

# ========================================
# APPLICATION CONFIGURATION
# ========================================

NODE_ENV=production

# Server
PORT=3000
API_PREFIX=api
API_VERSION=1

# ========================================
# CORS CONFIGURATION
# ========================================

CORS_ENABLED=true
CORS_ORIGINS=https://your-frontend-domain.com,https://app.your-domain.com

# ========================================
# RATE LIMITING (Production: Stricter)
# ========================================

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ========================================
# AUTHENTICATION
# ========================================

# JWT (CRITICAL: Use strong secret, minimum 32 characters)
JWT_SECRET=GENERATE_SECURE_RANDOM_STRING_MINIMUM_32_CHARS
JWT_EXPIRATION=3600

# OTP Provider (Production credentials)
OTP_PROVIDER=twilio
OTP_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OTP_AUTH_TOKEN=your_production_twilio_auth_token
OTP_FROM_NUMBER=+1234567890

# ========================================
# PAYMENT GATEWAY
# ========================================

PAYMENT_GATEWAY=razorpay
PAYMENT_KEY_ID=rzp_live_XXXXXXXXXXXXX
PAYMENT_KEY_SECRET=your_production_payment_key_secret

# ========================================
# DELIVERY AGGREGATOR
# ========================================

DELIVERY_PROVIDER=dunzo
DELIVERY_API_KEY=your_production_delivery_api_key
DELIVERY_CLIENT_ID=your_production_delivery_client_id

# ========================================
# FILE STORAGE (Production S3)
# ========================================

S3_BUCKET=your-production-bucket
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
S3_SECRET_ACCESS_KEY=your_production_s3_secret_key
S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com

# ========================================
# NOTIFICATIONS
# ========================================

# Firebase Cloud Messaging
FCM_SERVER_KEY=your_production_fcm_server_key

# SMS Provider
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SMS_AUTH_TOKEN=your_production_twilio_auth_token
SMS_FROM_NUMBER=+1234567890

# ========================================
# MONITORING & LOGGING (Optional)
# ========================================

# Sentry
# SENTRY_DSN=https://xxxx@sentry.io/xxxxx

# New Relic
# NEW_RELIC_LICENSE_KEY=your_license_key
# NEW_RELIC_APP_NAME=mvp-api-production
