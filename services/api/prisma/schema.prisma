// ========================================
// PRISMA SCHEMA - MVP v1
// ========================================
// Local Commerce Coordination Platform
// Category-agnostic order coordination
// MVP: Printing only (extensible by design)
// ========================================

// ========================================
// PRISMA v7 GENERATOR CONFIGURATION
// ========================================
// Generates TypeScript client for Prisma v7
// Output: node_modules/@prisma/client

generator client {
  provider = "prisma-client-js"
}

// ========================================
// DATABASE DATASOURCE CONFIGURATION
// ========================================
// Prisma v7: URLs removed from schema (deprecated)
// Connection URLs must be provided via:
// 1. Environment variable DATABASE_URL (for migrations)
// 2. --url flag: npx prisma migrate dev --url=$DATABASE_URL
// 3. PrismaClient constructor (for application runtime)
//
// Production strategy:
// - DATABASE_URL: Connection pooled (used by app runtime)
// - DATABASE_DIRECT_URL: Direct connection (used by migrations)
//
// Migration command:
//   DATABASE_URL="postgresql://..." npx prisma migrate dev --name init
//   OR
//   npx prisma migrate dev --url="postgresql://..." --name init

datasource db {
  provider = "postgresql"
  
}

// ========================================
// ENUMS
// ========================================

enum UserRole {
  USER   // End users placing orders
  SELLER // Shop owners fulfilling orders
  ADMIN  // Internal operations team
}

enum SellerStatus {
  ONLINE  // Actively accepting orders
  OFFLINE // Not accepting orders (default after login)
}

enum OrderStatus {
  // Happy path states
  CREATED            // Order draft created, no seller selected
  SELLER_SELECTED    // User selected a seller
  PAID               // Payment successful
  SELLER_ACCEPTED    // Seller accepted the order
  PREPARING          // Seller is preparing the order
  READY_FOR_PICKUP   // Order ready, delivery assignment triggered
  PICKED_UP          // Delivery partner picked up
  DELIVERED          // Order completed successfully
  
  // Failure states
  SELLER_REJECTED    // Seller rejected the order
  ORDER_EXPIRED      // Order expired (timeout)
  DELIVERY_FAILED    // Delivery partner failed
  USER_CANCELLED     // User cancelled (pre-pickup only)
}

enum CategoryStatus {
  ACTIVE       // Category is live
  COMING_SOON  // Category visible but not functional
  INACTIVE     // Category hidden
}

enum PaymentStatus {
  PENDING    // Payment initiated
  SUCCESS    // Payment successful
  FAILED     // Payment failed
  REFUNDED   // Payment refunded
}

enum PaymentMethod {
  UPI        // UPI payment (MVP only method)
  CASH       // Cash on delivery (future)
  CARD       // Card payment (future)
}

enum DeliveryStatus {
  PENDING          // Delivery not yet assigned
  ASSIGNED         // Delivery partner assigned
  PICKED_UP        // Item picked up from seller
  IN_TRANSIT       // On the way to customer
  DELIVERED        // Successfully delivered
  FAILED           // Delivery failed
  CANCELLED        // Delivery cancelled
}

// ========================================
// USER MODEL
// ========================================
// Represents users (customers, sellers, admins)
// Created automatically on OTP verification
// Phone is unique identifier (no username/password)

model User {
  id        String   @id @default(cuid())
  phone     String   @unique // Format: +91XXXXXXXXXX
  role      UserRole // MUST be explicitly assigned at creation (USER | SELLER | ADMIN)
  
  // Optional profile (can be null initially)
  name      String?
  email     String?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  orders    Order[]       @relation("UserOrders")
  seller    Seller?       // One-to-one: User can be a Seller
  otps      Otp[]         // OTP history
  
  @@index([phone])
  @@index([role])
  @@map("users")
}

// ========================================
// OTP MODEL
// ========================================
// Temporary OTP storage for authentication
// TTL: 5 minutes
// Rate limit: 5 requests per hour per phone

model Otp {
  id        String   @id @default(cuid())
  phone     String   // Phone number OTP was sent to
  code      String   // 6-digit OTP code
  role      UserRole // Role requested during OTP generation
  
  // Security
  attempts  Int      @default(0) // Failed verification attempts
  verified  Boolean  @default(false)
  
  // Timestamps
  expiresAt DateTime // 5 minutes from creation
  createdAt DateTime @default(now())
  
  // Relations
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([phone, expiresAt])
  @@index([phone, code]) // Composite index for OTP lookup (phone + code verification)
  @@map("otps")
}

// ========================================
// SELLER MODEL
// ========================================
// Shop owners who fulfill orders
// One-to-one with User (Seller extends User)
// Location stored as lat/lng for distance calculations

model Seller {
  id          String       @id @default(cuid())
  userId      String       @unique // One seller per user
  
  // Shop details
  shopName    String
  address     String
  latitude    Decimal      @db.Decimal(10, 8) // Precision for accurate distance
  longitude   Decimal      @db.Decimal(11, 8)
  
  // Availability (CRITICAL for order routing)
  status           SellerStatus @default(OFFLINE) // Default OFFLINE after login
  statusUpdatedAt  DateTime?                      // Set ONLY when seller changes availability status (nullable initially)
  
  // Pricing (category-specific, MVP: printing only)
  pricePerPage     Decimal?     @db.Decimal(10, 2) // Price per page for printing
  
  // Estimated prep time in minutes
  prepTimeMinutes  Int?         @default(15)
  
  // Categories this seller supports
  categories       SellerCategory[]
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]  @relation("SellerOrders")
  
  @@index([status]) // Critical: filter by ONLINE sellers
  @@index([latitude, longitude]) // Geospatial queries
  @@index([userId])
  @@map("sellers")
}

// ========================================
// CATEGORY MODEL
// ========================================
// Static list of service categories
// MVP: Only "Printing" is ACTIVE
// Seeded during initial migration

model Category {
  id          String         @id // e.g., "printing", "stationery"
  name        String         // Display name
  status      CategoryStatus @default(COMING_SOON)
  description String?
  
  // Order for display
  displayOrder Int           @default(0)
  
  // Timestamps
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  // Relations
  sellers     SellerCategory[]
  orders      Order[]
  
  @@index([status])
  @@map("categories")
}

// ========================================
// SELLER CATEGORY (JOIN TABLE)
// ========================================
// Many-to-many: Sellers can support multiple categories

model SellerCategory {
  id         String   @id @default(cuid())
  sellerId   String
  categoryId String
  
  // Category-specific pricing can go here
  // For now, using pricePerPage on Seller model
  
  createdAt  DateTime @default(now())
  
  seller     Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  @@unique([sellerId, categoryId])
  @@index([sellerId])
  @@index([categoryId])
  @@map("seller_categories")
}

// ========================================
// ORDER MODEL (CENTRAL AGGREGATE)
// ========================================
// Core domain object - everything revolves around Order
// Order payload is category-agnostic (stored as JSON)
// State machine enforced at application level

model Order {
  id              String      @id @default(cuid())
  
  // References
  userId          String
  sellerId        String?     // Null until seller selected
  categoryId      String
  
  // Order payload (category-agnostic JSON)
  // For printing: { file_url, pages, copies, color, notes }
  orderPayload    Json
  
  // State machine
  status          OrderStatus @default(CREATED)
  
  // Pricing breakdown (all in INR, stored as Decimal for accuracy)
  itemCost        Decimal?    @db.Decimal(10, 2)
  deliveryFee     Decimal?    @db.Decimal(10, 2)
  totalAmount     Decimal?    @db.Decimal(10, 2)
  
  // Delivery location (stored when user requests quote)
  dropLatitude    Decimal?    @db.Decimal(10, 8)
  dropLongitude   Decimal?    @db.Decimal(11, 8)
  dropAddress     String?
  
  // Rejection/cancellation reason (if applicable)
  failureReason   String?
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  completedAt     DateTime?   // Set ONLY when order status transitions to DELIVERED (nullable until completion)
  
  // Relations
  user            User        @relation("UserOrders", fields: [userId], references: [id], onDelete: Restrict)
  seller          Seller?     @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Restrict)
  category        Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  
  stateHistory    OrderStateHistory[]
  payment         Payment?
  delivery        Delivery?
  files           File[]
  
  @@index([userId])
  @@index([sellerId])
  @@index([status]) // Critical: filter orders by status
  @@index([categoryId])
  @@index([createdAt])
  @@index([status, createdAt]) // Composite for admin filtering
  @@map("orders")
}

// ========================================
// ORDER STATE HISTORY
// ========================================
// Audit log of all state transitions
// Critical for debugging and business intelligence
// Immutable - never updated or deleted

model OrderStateHistory {
  id          String      @id @default(cuid())
  orderId     String
  
  // State transition
  fromStatus  OrderStatus?  // Null for initial CREATED state
  toStatus    OrderStatus
  
  // Who/what triggered the transition
  triggeredBy String?       // userId or "system"
  reason      String?       // Optional reason for transition
  
  // Timestamp
  createdAt   DateTime    @default(now())
  
  // Relations
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  @@index([orderId])
  @@index([createdAt])
  @@map("order_state_history")
}

// ========================================
// PAYMENT MODEL
// ========================================
// One payment per order (no split payments in MVP)
// Payment must succeed before order moves to PAID status

model Payment {
  id                String        @id @default(cuid())
  orderId           String        @unique // One payment per order
  
  // Payment details
  amount            Decimal       @db.Decimal(10, 2)
  method            PaymentMethod @default(UPI)
  status            PaymentStatus @default(PENDING)
  
  // Payment gateway details
  gatewayName       String?       // "razorpay", "paytm", etc.
  gatewayOrderId    String?       // External order ID
  gatewayPaymentId  String?       // External payment ID
  gatewaySignature  String?       // Webhook signature verification
  
  // UPI details
  upiId             String?
  upiTransactionId  String?
  
  // Failure details
  failureReason     String?
  failureCode       String?
  
  // Refund tracking
  refundAmount      Decimal?      @db.Decimal(10, 2)
  refundStatus      String?
  refundedAt        DateTime?
  
  // Timestamps
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  paidAt            DateTime?     // When payment succeeded
  
  // Relations
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  
  @@index([orderId])
  @@index([status])
  @@index([gatewayPaymentId])
  @@map("payments")
}

// ========================================
// DELIVERY MODEL
// ========================================
// Delivery coordination via third-party aggregators
// One delivery per order
// Assigned when order reaches READY_FOR_PICKUP

model Delivery {
  id                  String         @id @default(cuid())
  orderId             String         @unique // One delivery per order
  
  // Provider details (Dunzo, Porter, etc.)
  providerName        String?        // "dunzo", "porter", etc.
  providerTaskId      String?        // External task ID
  providerTrackingUrl String?
  
  // Delivery status
  status              DeliveryStatus @default(PENDING)
  
  // Pickup details (seller location)
  // NOTE: These are SNAPSHOTS taken at delivery assignment time
  // They do not update if seller moves or changes address
  pickupLatitude      Decimal        @db.Decimal(10, 8)
  pickupLongitude     Decimal        @db.Decimal(11, 8)
  pickupAddress       String
  
  // Drop details (user location)
  dropLatitude        Decimal        @db.Decimal(10, 8)
  dropLongitude       Decimal        @db.Decimal(11, 8)
  dropAddress         String
  
  // Delivery partner details
  partnerName         String?
  partnerPhone        String?
  
  // Pricing
  quotedFee           Decimal?       @db.Decimal(10, 2)
  actualFee           Decimal?       @db.Decimal(10, 2)
  
  // Failure details
  failureReason       String?
  
  // Timestamps
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  assignedAt          DateTime?      // When delivery was assigned
  pickedUpAt          DateTime?      // When item was picked up
  deliveredAt         DateTime?      // When delivery completed
  
  // Relations
  order               Order          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  
  @@index([orderId])
  @@index([status])
  @@index([providerTaskId])
  @@map("deliveries")
}

// ========================================
// FILE MODEL
// ========================================
// Metadata for uploaded files (PDFs, images, etc.)
// Actual files stored in S3
// Immutable - files are never updated

model File {
  id              String   @id @default(cuid())
  orderId         String
  
  // File details
  originalName    String   // Original filename
  mimeType        String   // "application/pdf", "image/png", etc.
  sizeBytes       Int      // File size in bytes
  
  // Storage details (S3 or equivalent)
  storageKey      String   // S3 key/path
  storageUrl      String   // Full S3 URL (or presigned URL)
  bucket          String?  // S3 bucket name
  
  // File validation
  validated       Boolean  @default(false)
  validationError String?  // If validation failed
  
  // For printing: auto-detected page count
  pageCount       Int?
  
  // Timestamps
  createdAt       DateTime @default(now())
  
  // Relations
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  @@index([orderId])
  @@index([storageKey])
  @@map("files")
}

// ========================================
// NOTES ON SCHEMA DESIGN
// ========================================
//
// 1. ORDER AS CENTRAL AGGREGATE
//    Everything revolves around Order. Order holds references
//    to User, Seller, Category, Payment, Delivery, Files.
//
// 2. CATEGORY-AGNOSTIC DESIGN
//    orderPayload is JSON - each category defines its own schema
//    Printing: { file_url, pages, copies, color, notes }
//    Future categories add their own payload structures
//
// 3. SELLER AVAILABILITY ENFORCEMENT
//    SellerStatus is indexed - critical for order routing
//    Only ONLINE sellers should appear in discovery
//
// 4. STATE MACHINE AUDIT TRAIL
//    OrderStateHistory tracks ALL transitions immutably
//    Essential for debugging and business intelligence
//
// 5. PAYMENT & DELIVERY COORDINATION
//    One-to-one relationships with Order
//    Order status drives payment and delivery workflows
//
// 6. GEOSPATIAL READY
//    Decimal(10,8) and Decimal(11,8) for lat/lng precision
//    Indexed for distance calculations
//    Can upgrade to PostGIS if needed later
//
// 7. NO SOFT DELETES
//    Keep it simple - hard deletes or null relations
//    Can add deletedAt later if needed
//
// 8. INDEXES FOR PERFORMANCE
//    - User lookups: phone, role
//    - Seller discovery: status, location
//    - Order filtering: status, userId, sellerId, createdAt
//    - Payment tracking: status, gatewayPaymentId
//    - Delivery tracking: status, orderId
//
// 9. DECIMAL FOR MONEY
//    Always use Decimal for currency (never Float)
//    Precision 10,2 for rupees (up to 99,999,999.99)
//
// 10. TIMESTAMPS EVERYWHERE
//     createdAt, updatedAt on all mutable tables
//     Specific timestamps for business events (paidAt, deliveredAt)
//
